print("===== SIMPLE CHATBOT =====")
print("welcome to SIMPLE CHATBOT")
print("Start chatting and the bot will respond to your messages.")
print("You can say hello, ask simple questions, or type 'bye' to end the conversation.")

while True:

    user = input("You: ")

    user = user.lower()

    if user == "hello":
        print("Bot: Hi! Nice to meet you.")

    elif user == "how are you":
        print("Bot: I am fine. How are you?")

    elif user == "what is your name":
        print("Bot: My name is Simple Chatbot.")

    elif user == "bye":
        print("Bot: Goodbye!")
        break

    else:
        print("Bot: Sorry, I don't understand.")
