import random

print("===== HANGMAN GAME =====")
print("Welcome to the Hungman Challenge!")
print("Test your guessing skills by finding the hidden word one letter at a time.")
print("Be carefull! You have limited chances, So think wisely and try to win the game before your chances run out: ")

words = ["matsya","kurma","varaha","narasimha","vamana","parashurama","rama","krishna","buddha","kalki"]

word = random.choice(words)

guesses = ""

chances = 7

while chances > 0:

    failed = 0

    for letter in word:

        if letter in guesses:
            print(letter, end=" ")

        else:
            print("_")
            failed += 1

    if failed == 0:
        print("\nYou Won!")
        print("The Word is:", word)
        break

    guess = input("\nGuess a letter: ")

    guesses += guess

    if guess not in word:

        chances -= 1

        print("Wrong Guess")

        print("int:The word to be guess is a character name in Dashavataram")
        print("Remaining Chances:", chances)

if chances == 0:
    print("You Lost")
    print("Correct Word is:", word)
